  "liveNow": false,
  "panels": [
    {
      "title": "Kafka Consumer Lag — Ledger",
      "description": "Consumer lag for betsafe-ledger-consumer. Primary pipeline health signal — high lag means events are backing up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "betsafe_kafka_consumer_lag{consumer_group=\"betsafe-ledger-consumer\"}",
          "legendFormat": "{{topic}} - p{{partition}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Kafka Consumer Lag — Archive",
      "description": "Consumer lag for betsafe-archive-consumer. High lag means Parquet archive is falling behind.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "betsafe_kafka_consumer_lag{consumer_group=\"betsafe-archive-consumer\"}",
          "legendFormat": "{{topic}} - p{{partition}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Events/sec by Tenant",
      "description": "Rate of accepted events per tenant per second. Shows ingestion throughput.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(betsafe_events_accepted_total[1m])",
          "legendFormat": "{{tenant_id}} - {{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      }
    },
    {
      "title": "Acceptance Rate %",
      "description": "Percentage of received events that were accepted. Below 90% triggers a warning.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(betsafe_events_accepted_total[5m])) / sum(rate(betsafe_events_received_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Rate Limit Rejections/sec",
      "description": "Rate of 429 responses per tenant. Spikes indicate tenant is exceeding their EPS allocation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(betsafe_rate_limit_exceeded_total[1m])",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      }
    },
    {
      "title": "Ingestion Latency P50/P95/P99",
      "description": "Gateway receive to Kafka publish latency. P95 above 200ms triggers a warning.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(betsafe_event_ingestion_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(betsafe_event_ingestion_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(betsafe_event_ingestion_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      }
    },
    {
      "title": "Ledger Write Latency P95",
      "description": "Kafka consume to PostgreSQL insert latency. P95 above 500ms triggers a warning.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(betsafe_ledger_write_latency_seconds_bucket[5m]))",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      }
    },
    {
      "title": "Total Ledger Writes",
      "description": "Cumulative rows written to the PostgreSQL audit ledger per tenant.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "betsafe_ledger_writes_total",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Archive Files Uploaded",
      "description": "Total Parquet files uploaded to MinIO per tenant.",
